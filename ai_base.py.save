import json, time, logging, requests, os



logger = logging.getLogger("ai.base")
DS_KEY = "sk-9a1b435a95ac43489d926b87cb7f0fb9"
ALI_KEY = "sk-1c1b4e4cf221486c9fe3ccc6a4dc25b0"
ZX_KEY = "sk-VRPu7DBesQdqhY0GP2ufyJPqcqdUkYek"


class AIBase:
    """底座：管理 DeepSeek、阿里百炼、智象未来等所有模型"""

    def __init__(self):
        self.ds_key = ""
        self.ds_url = "https://api.deepseek.com/v1"
        self.ali_key = ""
        self.ali_url = "https://dashscope.aliyuncs.com/compatible-mode/v1"
        self.zx_key = ""
        self.zx_url = "https://api.zhixiang.ai/v1"
        self._init_keys()

    def _init_keys(self):
        import os
        self.ds_key = os.environ.get("DS_KEY", "") or self.ds_key
        self.ali_key = os.environ.get("ALI_KEY", "") or self.ali_key
        self.zx_key = os.environ.get("ZX_KEY", "") or self.zx_key

    def llm(self, system: str, user: str, temp=0.7, timeout=60) -> str:
        from openai import OpenAI
        import httpx
        t = httpx.HTTPTransport(verify=True, local_address="0.0.0.0")
        cli = OpenAI(api_key=self.ds_key, base_url=self.ds_url,
                     http_client=httpx.Client(transport=t, timeout=httpx.Timeout(timeout)))
        r = cli.chat.completions.create(model="deepseek-v4-flash",
            messages=[{"role":"system","content":system},{"role":"user","content":user}],
            temperature=temp, timeout=timeout)
        return r.choices[0].message.content or ""

    def llm_json(self, system: str, user: str, temp=0.3, timeout=60) -> dict:
        text = self.llm(system, user, temp, timeout).strip()
        if text.startswith("```"):
            idx = text.find("\n")
            if idx > 0: text = text[idx+1:]
            if text.endswith("```"): text = text[:-3]
        import json as j
        for fn in [j.loads, lambda t: j.loads(t[t.find("{"):t.rfind("}")+1]), lambda t: j.loads(t[t.find("["):t.rfind("]")+1])]:
            try: return fn(text)
            except: pass
        return {}

    def image(self, prompt: str) -> list:
        try:
            import dashscope; dashscope.api_key = self.ali_key
            from dashscope.aigc.image_generation import ImageGeneration
            from dashscope.api_entities.dashscope_response import Message
            r = ImageGeneration.call(model="wan2.7-image", api_key=self.ali_key,
                messages=[Message(role="user",content=[{"text":prompt}])],
                watermark=False, n=1, size="1024*1024", timeout=120)
            if r.status_code == 200:
                return [ct["image"] for c in r.output.choices for ct in c["message"]["content"] if ct.get("type")=="image"]
        except Exception as e:
            logger.warning(f"阿里图片失败: {e}")
        try:
            r = requests.post(f"{self.zx_url}/images/generations",
                headers={"Authorization":f"Bearer {self.zx_key}","Content-Type":"application/json"},
                json={"model":"z1-image","prompt":prompt,"size":"1024x1024","n":1}, timeout=120)
            if r.status_code == 200:
                return [item["url"] for item in r.json().get("data",[]) if item.get("url")]
        except Exception as e:
            logger.warning(f"智象图片失败: {e}")
        return []

    def tts(self, text: str, voice="longxiaoxia") -> bytes:
        try:
            import dashscope; dashscope.api_key = self.ali_key
            from dashscope.audio.tts_v2 import SpeechSynthesizer, AudioFormat
            s = SpeechSynthesizer(model="cosyvoice-v1", voice=voice,
                format=AudioFormat.MP3_16000HZ_MONO_128KBPS)
            r = s.call(text=text)
            if isinstance(r, bytes) and len(r) > 100: return r
        except Exception as e:
            logger.warning(f"阿里TTS SDK失败: {e}")
        try:
            r = requests.post("https://dashscope.aliyuncs.com/api/v1/services/tts/cosyvoice",
                headers={"Authorization":f"Bearer {self.ali_key}","Content-Type":"application/json"},
                json={"model":"cosyvoice-v1","input":{"text":text},"parameters":{"voice":voice,"format":"mp3","sample_rate":16000}},
                timeout=60)
            if r.status_code == 200:
                u = r.json().get("output",{}).get("audio_url","")
                if u:
                    ar = requests.get(u, timeout=30)
                    return ar.content if ar.status_code == 200 else b""
        except Exception as e:
            logger.error(f"阿里TTS REST失败: {e}")
        return b""

    def video(self, prompt: str) -> str:
        try:
            r = requests.post(f"{self.zx_url}/videos/generations",
                headers={"Authorization":f"Bearer {self.zx_key}","Content-Type":"application/json"},
                json={"model":"z1-video","prompt":prompt,"duration":5,"resolution":"720p"}, timeout=30)
            if r.status_code != 200: return ""
            tid = r.json().get("data",{}).get("id","")
            if not tid: return ""
            for _ in range(60):
                time.sleep(5)
                q = requests.get(f"{self.zx_url}/videos/{tid}",
                    headers={"Authorization":f"Bearer {self.zx_key}"}, timeout=10)
                if q.status_code == 200:
                    st = q.json().get("data",{}).get("status","")
                    if st == "completed": return q.json()["data"]["video"]["url"]
                    if st == "failed": return ""
        except Exception as e:
            logger.error(f"智象视频失败: {e}")
        return ""


ai = AIBase()

# 兼容旧引用
class DeepSeekProvider:
    def __init__(self):
        from openai import OpenAI
        import httpx
        t = httpx.HTTPTransport(verify=True, local_address="0.0.0.0")
        self.client = OpenAI(api_key=", base_url="https://api.deepseek.com",
                             http_client=httpx.Client(transport=t, timeout=httpx.Timeout(60.0)))
    def get_model_for_agent(self, aid):
        return "deepseek-v4-flash"
    def _call(self, system, user, temp=0.7, agent_id=None, **kw):
        return ai.llm(system, user, temp, kw.get("timeout", 60))

deepseek = DeepSeekProvider()
agnes = DeepSeekProvider()
